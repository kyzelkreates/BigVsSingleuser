# ============================================================
# Big V's Best Routes™ — Environment Variables (.env.example)
# Powered by 4P3X Intelligent AI™ | Created by Kyzel Kreates™
# Run 8 — Backend-Ready Deployment Centre
#
# ── IMPORTANT ─────────────────────────────────────────────────
# This file contains FRONTEND-SAFE PUBLIC CONFIG ONLY.
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# NEVER place backend-only secrets here.
#
# ── 4P3X API Config Guard™ ────────────────────────────────────
# The following MUST NEVER appear in this file, frontend code,
# public files, GitHub commits, logs, or browser storage:
#
#   SUPABASE_SERVICE_ROLE_KEY
#   OPENAI_API_KEY
#   GROQ_API_KEY
#   STRIPE_SECRET_KEY
#   DATABASE_URL
#   JWT_SECRET
#   PRIVATE_KEY
#   WEBHOOK_SECRET
#   Admin tokens
#   Any backend-only secret
#
# Place those ONLY in server-side environment (Vercel, Railway,
# Supabase Edge Functions, AWS Lambda, etc.).
# ============================================================

# ── App Mode ─────────────────────────────────────────────────
VITE_ENABLE_DEMO_MODE=true
# Set to false in production after backend is configured.

# ── Supabase (public/frontend-safe config only) ────────────────
# Use the ANON/PUBLIC key — NEVER the service_role key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Firebase (public client config only) ──────────────────────
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=

# ── Custom / REST Backend (public base URL only) ───────────────
VITE_PUBLIC_API_BASE_URL=
VITE_PUBLIC_HEALTH_ENDPOINT=

# ── Map Providers (public keys only) ─────────────────────────
VITE_MAP_PROVIDER=osm
# OSM is always the free default. GraphHopper/Mapbox are optional.
VITE_GRAPHHOPPER_API_KEY=
VITE_MAPBOX_TOKEN=

# ── 4P3X Intelligent AI™ (public-safe only) ──────────────────
# These are client-side AI provider keys ONLY.
# Route all secret AI backend calls through your server layer.
VITE_OPENROUTER_API_KEY=
VITE_DEEPSEEK_API_KEY=
VITE_MISTRAL_API_KEY=

# ── Advisory / Safety ─────────────────────────────────────────
# Big V's Best Routes™ is advisory only. It does not guarantee
# route safety, legal compliance, or restriction clearance.
# Drivers remain responsible for checking road signs,
# restrictions, and professional judgement.
