# ============================================================
# Big V's Best Routes™ — Environment Variables (.env.example)
# Powered by 4P3X Intelligent AI™ | Created by Kyzel Kreates™
# Run 13 — Final Production Readiness
#
# ── HOW TO USE ────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The .env file must NEVER be committed to version control.
# .env is already in .gitignore — verify before pushing.
#
# ── CLIENT-SAFE KEYS ONLY ────────────────────────────────────
# This file contains FRONTEND-SAFE PUBLIC CONFIG ONLY.
# All VITE_* variables are baked into the build bundle and
# visible in the browser. Never put server-side secrets here.
#
# ── 4P3X API Config Guard™ — FORBIDDEN VARIABLES ─────────────
# The following MUST NEVER appear in this file, frontend source,
# GitHub commits, build output, browser storage, or logs:
#
#   SUPABASE_SERVICE_ROLE_KEY   ← never in frontend
#   DATABASE_URL                ← never in frontend
#   JWT_SECRET                  ← never in frontend
#   PRIVATE_KEY                 ← never in frontend
#   WEBHOOK_SECRET              ← never in frontend
#   OPENAI_API_KEY              ← server-side only
#   GROQ_API_KEY                ← server-side only
#   STRIPE_SECRET_KEY           ← server-side only
#   Admin tokens                ← server-side only
#   Any backend-only secret     ← server-side only
#
# Place those ONLY in Vercel Environment Variables (server),
# Supabase Edge Functions, AWS Lambda, or equivalent.
# ============================================================


# ── App Mode ──────────────────────────────────────────────────
# Set to true to start in Demo Mode (no backend needed).
# Set to false in production when Supabase is configured.
# If unset, the app uses Demo Mode by default.
VITE_DEMO_MODE_DEFAULT=true


# ── Supabase (public/frontend-safe config only) ────────────────
# Use the ANON/PUBLIC key — NEVER the service_role key here.
# Both are found in: Supabase Dashboard → Project Settings → API
# Leave blank to use Demo Mode only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=


# ── Map Providers (public keys / public base URLs only) ────────
# OSM is the free default — no key required.
VITE_MAP_PROVIDER=osm

# GraphHopper (optional — route calculation)
# Free tier available. Get key at: graphhopper.com
VITE_GRAPHHOPPER_API_KEY=

# Mapbox (optional — alternative tile/routing provider)
VITE_MAPBOX_TOKEN=

# Google Maps (optional)
VITE_GOOGLE_MAPS_API_KEY=


# ── 4P3X Intelligent AI™ (client-side AI providers — optional) ─
# These are PUBLIC-SAFE client-side keys for providers that
# support browser-side usage (e.g. OpenRouter free tier).
# Route all SECRET AI calls through your server layer instead.
# Leave blank to use local/offline AI advisory mode.
VITE_OPENROUTER_API_KEY=
VITE_DEEPSEEK_API_KEY=
VITE_MISTRAL_API_KEY=
VITE_ANTHROPIC_API_KEY=
VITE_GEMINI_API_KEY=
VITE_OLLAMA_BASE_URL=

# ── Advisory (read before deploying) ─────────────────────────
# Big V's Best Routes™ is advisory route-planning support only.
# The platform does not guarantee legal compliance, route safety,
# or restriction clearance. Drivers/operators remain responsible
# for checking road signs, restrictions, and professional judgement.
